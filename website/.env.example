# Local development only. Copy to .env and replace with your own values.
# Safe example values are included for local self-hosted testing only.
# Use localhost when running the app directly on your machine.
# Use db as the host when running the app inside docker compose.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/educore?schema=public"
AUTH_SECRET="replace-with-a-long-random-string"
# Optional: enable real planner draft generation through an OpenAI-compatible API.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com/v1"
